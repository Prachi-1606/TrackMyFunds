# ── Build output ──────────────────────────────────────────────────────────────
target/
*.jar
*.war
*.class

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
.classpath
.project
.settings/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log

# ── Local secrets (NEVER commit) ──────────────────────────────────────────────
.env
.env.local
.env.*.local
application-local.properties
secrets.properties

